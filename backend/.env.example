# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection Strings (Neon PostgreSQL)
DATABASE_URL="postgresql://devuser:devpassword@localhost:5433/nextgen_dev?schema=public"
DIRECT_URL="postgresql://devuser:devpassword@localhost:5433/nextgen_dev?schema=public"

# CORS Configuration
CLIENT_URL=http://localhost:5173

# Authentication Secrets
JWT_SECRET=local_development_jwt_secret_key_12345

# Cloudinary Integration (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP Transactional Email Config (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="NextGen Operations <no-reply@nextgenerp.com>"
