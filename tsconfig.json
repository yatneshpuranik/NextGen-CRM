{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["backend/node_modules/@prisma/client"],
      "@prisma/client/*": ["backend/node_modules/@prisma/client/*"],
      ".prisma/client": ["backend/node_modules/.prisma/client"],
      ".prisma/client/*": ["backend/node_modules/.prisma/client/*"]
    }
  },
  "include": [
    "backend/src/**/*",
    "frontend/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "backend/dist",
    "frontend/dist"
  ]
}
